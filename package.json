{
  "name": "antigravity-quota-watcher",
  "displayName": "Antigravity Quota Watcher",
  "description": "实时监控 Antigravity的模型使用配额（displays AI model quota status in the status bar）",
  "version": "2.0.1",
  "publisher": "wusimpl",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravity-quota-watcher.refreshQuota",
        "title": "%command.refreshQuota%"
      },
      {
        "command": "antigravity-quota-watcher.detectPort",
        "title": "%command.detectPort%"
      },
      {
        "command": "antigravity-quota-watcher.dev.previewNotifications",
        "title": "Antigravity Dev: 预览通知弹窗"
      },
      {
        "command": "antigravity-quota-watcher.dev.previewStatusBar",
        "title": "Antigravity Dev: 预览状态栏文本"
      },
      {
        "command": "antigravity-quota-watcher.dev.previewTooltip",
        "title": "Antigravity Dev: 预览 Tooltip"
      },
      {
        "command": "antigravity-quota-watcher.googleLogin",
        "title": "%command.googleLogin%"
      },
      {
        "command": "antigravity-quota-watcher.googleLogout",
        "title": "%command.googleLogout%"
      },
      {
        "command": "antigravity-quota-watcher.openDashboard",
        "title": "%command.openDashboard%"
      }
    ],
    "configuration": {
      "title": "Antigravity Quota Watcher",
      "properties": {
        "antigravityQuotaWatcher.enabled": {
          "type": "boolean",
          "default": true,
          "description": "%config.enabled%",
          "order": 10
        },
        "antigravityQuotaWatcher.pollingInterval": {
          "type": "number",
          "default": 60,
          "description": "%config.pollingInterval%",
          "order": 20
        },
        "antigravityQuotaWatcher.displayStyle": {
          "type": "string",
          "default": "percentage",
          "enum": [
            "percentage",
            "progressBar",
            "dots"
          ],
          "enumDescriptions": [
            "Show percentage / 显示百分比 (e.g. 🟢 Claude: 85%)",
            "Show progress bar / 显示方块进度条 (e.g. 🟢 Claude ███████░)",
            "Show dots / 显示圆点进度条 (e.g. 🟢 Claude ●●●●○)"
          ],
          "description": "%config.displayStyle%",
          "order": 30
        },
        "antigravityQuotaWatcher.apiMethod": {
          "type": "string",
          "default": "GOOGLE_API",
          "enum": [
            "GET_USER_STATUS",
            "GOOGLE_API"
          ],
          "enumDescriptions": [
            "%config.apiMethod.getUserStatus%",
            "%config.apiMethod.googleApi%"
          ],
          "description": "%config.apiMethod%",
          "order": 40
        },
        "antigravityQuotaWatcher.warningThreshold": {
          "type": "number",
          "default": 50,
          "description": "%config.warningThreshold%",
          "order": 50
        },
        "antigravityQuotaWatcher.criticalThreshold": {
          "type": "number",
          "default": 30,
          "description": "%config.criticalThreshold%",
          "order": 60
        },
        "antigravityQuotaWatcher.showPromptCredits": {
          "type": "boolean",
          "default": false,
          "description": "%config.showPromptCredits%",
          "order": 70
        },
        "antigravityQuotaWatcher.showPlanName": {
          "type": "boolean",
          "default": false,
          "description": "%config.showPlanName%",
          "order": 72
        },
        "antigravityQuotaWatcher.showGeminiPro": {
          "type": "boolean",
          "default": true,
          "description": "%config.showGeminiPro%",
          "order": 73
        },
        "antigravityQuotaWatcher.showGeminiFlash": {
          "type": "boolean",
          "default": true,
          "description": "%config.showGeminiFlash%",
          "order": 74
        },
        "antigravityQuotaWatcher.forcePowerShell": {
          "type": "boolean",
          "default": true,
          "description": "%config.forcePowerShell%",
          "order": 75
        },
        "antigravityQuotaWatcher.language": {
          "type": "string",
          "default": "zh-cn",
          "enum": [
            "auto",
            "en",
            "zh-cn"
          ],
          "enumDescriptions": [
            "Auto (Based on VS Code language) / 自动 (跟随 VS Code 语言)",
            "English",
            "Chinese (Simplified) / 简体中文"
          ],
          "description": "%config.language%",
          "order": 80
        },
        "antigravityQuotaWatcher.logLevel": {
          "type": "string",
          "default": "DEBUG",
          "enum": [
            "ERROR",
            "WARNING",
            "INFO",
            "DEBUG"
          ],
          "enumDescriptions": [
            "ERROR - Only show errors / 仅显示错误",
            "WARNING - Show warnings and errors / 显示警告和错误",
            "INFO - Show important information / 显示重要信息",
            "DEBUG - Show all logs (default) / 显示所有日志（默认）"
          ],
          "description": "%config.logLevel%",
          "order": 90
        },
        "antigravityQuotaWatcher.proxyEnabled": {
          "type": "boolean",
          "default": false,
          "description": "%config.proxyEnabled%",
          "order": 100
        },
        "antigravityQuotaWatcher.proxyAutoDetect": {
          "type": "boolean",
          "default": true,
          "description": "%config.proxyAutoDetect%",
          "order": 101
        },
        "antigravityQuotaWatcher.proxyUrl": {
          "type": "string",
          "default": "",
          "description": "%config.proxyUrl%",
          "order": 102
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "package": "npx vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/sql.js": "^1.4.9",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.3.0",
    "vsce": "^2.15.0"
  },
  "dependencies": {
    "https": "^1.0.0",
    "https-proxy-agent": "^7.0.6",
    "sql.js": "^1.10.2"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/wusimpl/AntigravityQuotaWatcher.git"
  },
  "keywords": [
    "antigravity",
    "quota",
    "monitor",
    "ai"
  ],
  "author": "wusimpl",
  "homepage": "https://github.com/wusimpl/AntigravityQuotaWatcher",
  "bugs": {
    "url": "https://github.com/wusimpl/AntigravityQuotaWatcher/issues"
  },
  "license": "MIT"
}